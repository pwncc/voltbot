{
  "name": "@benricheson101/mira",
  "version": "1.0.0",
  "description": "",
  "main": "./build/src/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "biome lint .",
    "fmt": "biome check . --write",
    "typecheck": "tsc --noEmit",
    "mira:start": "node --enable-source-maps .",
    "mira:update-rag": "node --enable-source-maps ./build/scripts/updateRAG.js",
    "sim:chat": "pnpm build && node --enable-source-maps ./build/scripts/simulateChat.js",
    "sim:full": "pnpm build && node --enable-source-maps ./build/scripts/simulateFull.js",
    "sim:inspect": "pnpm build && node --enable-source-maps ./build/scripts/inspectSim.js",
    "testchat:replay": "pnpm build && node --enable-source-maps ./build/scripts/replayTestChat.js",
    "testchat:memory-stress": "pnpm build && node --enable-source-maps ./build/scripts/stressMemories.js",
    "testchat:memory-recall": "pnpm build && node --enable-source-maps ./build/scripts/testMemoryRecall.js"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@benricheson101/util": "^1.5.5",
    "@biomejs/biome": "^2.4.10",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.5.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.146",
    "ai-sdk-ollama": "^3.8.2",
    "discord.js": "^14.26.2",
    "sqlite-vec": "^0.1.9",
    "toml": "^3.0.0",
    "zod": "^4.3.6"
  }
}
